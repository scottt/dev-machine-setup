export NVM_DIR="$HOME/.nvm"
BREW_PREFIX=/home/linuxbrew/.linuxbrew
NVM_SCRIPT_DIR=$BREW_PREFIX/opt/nvm
[ -s "$NVM_SCRIPT_DIR/nvm.sh" ] && \. "$NVM_SCRIPT_DIR/nvm.sh"  --no-use # This loads nvm
[ -s "$NVM_SCRIPT_DIR/etc/bash_completion.d/nvm" ] && \. "$NVM_SCRIPT_DIR/etc/bash_completion.d/nvm"  # This loads nvm bash_completion
