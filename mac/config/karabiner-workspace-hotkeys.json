{
  "title": "Workspace Hotkeys",
  "rules": [
    {
      "description": "Use Command+Shift or remapped Option+Shift with H/J/K/L to switch to Mission Control desktops 1-4",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "h",
            "modifiers": {
              "mandatory": [
                "left_command",
                "left_shift"
              ]
            }
          },
          "to": [
            {
              "key_code": "1",
              "modifiers": [
                "left_control"
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "h",
            "modifiers": {
              "mandatory": [
                "left_option",
