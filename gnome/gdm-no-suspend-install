#!/bin/bash
# Configure the GDM login-screen GNOME session to not suspend the system when
# no user is logged in.
#
# GDM has its own dconf profile (/etc/dconf/profile/gdm) with a system-db named
# `gdm`, backed by /etc/dconf/db/gdm.d/. Dropping a keyfile there and running
# `dconf update` sets the defaults for the greeter session.
set -euo pipefail

src="$(dirname "$(readlink -f "$0")")/data/gdm-no-suspend.dconf-db"
dest=/etc/dconf/db/gdm.d/06-no-suspend

SUDO=
if [ "$(id -u)" -ne 0 ]; then
	SUDO=sudo
fi

$SUDO install -m 0644 "$src" "$dest"
$SUDO dconf update

echo "Installed $dest and ran dconf update."
